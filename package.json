{
  "name": "mermaid-validation-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that validates Mermaid diagrams in Markdown files",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --sourcemap --legal-comments=external",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "all": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/glob": "^0.7.0",
    "happy-dom": "^20.9.0",
    "mermaid": "^11.15.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^20.19.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.0"
  }
}
