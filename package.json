{
  "name": "mermaid-validation-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that validates Mermaid diagrams in Markdown files",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "all": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/glob": "^0.7.0",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.0"
  }
}
