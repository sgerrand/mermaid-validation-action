{
  "name": "mermaid-validation-action",
  "version": "0.2.0-alpha.1",
  "private": true,
  "description": "GitHub Action that validates Mermaid diagrams in Markdown files",
  "license": "BSD-2-Clause",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --sourcemap --legal-comments=external",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "lefthook install || true",
    "all": "bun run typecheck && bun run lint && bun test && bun run build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/glob": "^0.7.0",
    "happy-dom": "^20.9.0",
    "mermaid": "^11.15.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
